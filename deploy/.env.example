# Copy this file to deploy/.env and fill with real secrets locally.

# Infrastructure credentials
POSTGRES_USER=airflow
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=airflow
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=replace_me
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=replace_me
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:replace_me@postgres/airflow
DATABASE_URL=postgresql://airflow:replace_me@postgres:5432/airflow

# LLM providers
GOOGLE_API_KEY=replace_me
GROQ_API_KEY=replace_me
OPENAI_API_KEY=replace_me
TAVILY_API_KEY=replace_me

# Messaging
WHATSAPP_API_TOKEN=replace_me
WHATSAPP_PHONE_NUMBER_ID=replace_me
WHATSAPP_RECIPIENT_PHONE=replace_me
WHATSAPP_VERIFY_TOKEN=replace_me
